<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/sheet_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/shape_highlight_rule_sheet"
        android:clickable="true"
        android:focusable="true"
        android:orientation="vertical"
        android:paddingTop="12dp">

        <View
            android:id="@+id/drag_handle"
            android:layout_width="96dp"
            android:layout_height="8dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/shape_highlight_rule_handle" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="10dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp">

            <ImageView
                android:id="@+id/iv_back"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/shape_highlight_rule_icon_button"
                android:contentDescription="@string/back"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_back"
                android:tint="@color/primaryText" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_page_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/primaryText"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_page_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="自定义正文高亮规则"
                    android:textColor="@color/secondaryText"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_save_action"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:background="@drawable/shape_highlight_rule_save"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="@string/action_save"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:overScrollMode="ifContentScrolls">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingTop="10dp"
                android:paddingEnd="16dp"
                android:paddingBottom="28dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="基础信息"
                    android:textColor="@color/secondaryText"
                    android:textSize="13sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/shape_highlight_rule_surface"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="启用规则"
                                android:textColor="@color/primaryText"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="关闭后会保留规则，但不会作用到正文"
                                android:textColor="@color/secondaryText"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switch_enable"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="规则名称"
                        android:textColor="@color/primaryText"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/et_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/shape_highlight_rule_input"
                        android:hint="例如：对话高亮"
                        android:inputType="text"
                        android:minHeight="52dp"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="12dp"
                        android:textColor="@color/primaryText"
                        android:textColorHint="@color/secondaryText" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="所属分组"
                        android:textColor="@color/primaryText"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/sp_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/shape_highlight_rule_input"
                        android:minHeight="52dp"
                        android:paddingHorizontal="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="匹配规则"
                        android:textColor="@color/primaryText"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/et_pattern"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/shape_highlight_rule_input"
                        android:gravity="top|start"
                        android:hint="输入正则表达式"
                        android:inputType="textMultiLine"
                        android:minHeight="110dp"
                        android:padding="14dp"
                        android:textColor="@color/primaryText"
                        android:textColorHint="@color/secondaryText" />

                    <TextView
                        android:id="@+id/tv_pattern_error"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/error"
                        android:visibility="gone" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="样式设置"
                    android:textColor="@color/secondaryText"
                    android:textSize="13sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/shape_highlight_rule_surface"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="文字颜色"
                        android:textColor="@color/primaryText"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/et_text_color"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/shape_highlight_rule_input"
                        android:hint="#FFE58D2B"
                        android:inputType="textCapCharacters"
                        android:minHeight="52dp"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="12dp"
                        android:textColor="@color/primaryText"
                        android:textColorHint="@color/secondaryText" />

                    <TextView
                        android:id="@+id/tv_text_color_error"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/error"
                        android:visibility="gone" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="下划线样式"
                        android:textColor="@color/primaryText"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/sp_underline_mode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/shape_highlight_rule_input"
                        android:minHeight="52dp"
                        android:paddingHorizontal="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="下划线颜色"
                        android:textColor="@color/primaryText"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/et_underline_color"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/shape_highlight_rule_input"
                        android:hint="#FF63C37D"
                        android:inputType="textCapCharacters"
                        android:minHeight="52dp"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="12dp"
                        android:textColor="@color/primaryText"
                        android:textColorHint="@color/secondaryText" />

                    <TextView
                        android:id="@+id/tv_underline_color_error"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/error"
                        android:visibility="gone" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="预览文本"
                    android:textColor="@color/secondaryText"
                    android:textSize="13sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/shape_highlight_rule_surface"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="用于实时检查规则效果"
                        android:textColor="@color/secondaryText"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/et_sample_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/shape_highlight_rule_input"
                        android:gravity="top|start"
                        android:hint="输入一段示例文本，下面会即时预览"
                        android:inputType="textMultiLine"
                        android:minHeight="96dp"
                        android:padding="14dp"
                        android:textColor="@color/primaryText"
                        android:textColorHint="@color/secondaryText" />

                    <TextView
                        android:id="@+id/tv_preview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/shape_highlight_rule_preview"
                        android:lineSpacingExtra="8dp"
                        android:minHeight="96dp"
                        android:padding="16dp"
                        android:textColor="@color/primaryText"
                        android:textSize="18sp" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

</FrameLayout>
