<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">
        <!-- 鍒嗙粍鏍峰紡閫夋嫨 -->
        <LinearLayout
            android:id="@+id/ll_group_style"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintTop_toTopOf="parent">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingVertical="8dp"
                android:text="@string/group_style"
                android:textColor="@color/primaryText"
                android:textSize="14sp" />
            <androidx.appcompat.widget.AppCompatSpinner
                android:id="@+id/sp_group_style"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:entries="@array/group_style"
                android:theme="@style/Spinner"
                tools:ignore="TouchTargetSizeCheck" />
        </LinearLayout>
        <!-- 涓嬫媺閫夋嫨鍒嗙粍寮€鍏筹紙浠呭湪鍒嗙粍鏍峰紡涓烘爣绛炬椂鏄剧ず锛?-->
        <io.legado.app.lib.theme.view.ThemeSwitch
            android:id="@+id/sw_dropdown_select_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/dropdown_select_group"
            android:visibility="gone"
            android:paddingVertical="8dp"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@+id/ll_group_style" />
        <!-- 鏂囦欢澶硅鍥鹃€夋嫨锛堜粎鍦ㄥ垎缁勬牱寮忎负鏂囦欢澶规椂鏄剧ず锛?-->
        <LinearLayout
            android:id="@+id/ll_folder_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/ll_group_style">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingVertical="8dp"
                android:text="@string/folder_view"
                android:textColor="@color/primaryText"
                android:textSize="14sp" />
            <androidx.appcompat.widget.AppCompatSpinner
                android:id="@+id/sp_folder_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:entries="@array/book_view"
                android:theme="@style/Spinner"
                tools:ignore="TouchTargetSizeCheck" />
        </LinearLayout>
        <!-- Barrier 鐢ㄤ簬澶勭悊鍔ㄦ€佸彲瑙佹€х殑甯冨眬绾︽潫 -->
        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/barrier_after_group_options"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="ll_group_style,sw_dropdown_select_group,ll_folder_view" />
        <!-- 涔︾睄瑙嗗浘閫夋嫨 -->
        <LinearLayout
            android:id="@+id/ll_book_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@+id/barrier_after_group_options">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingVertical="8dp"
                android:text="@string/book_view"
                android:textColor="@color/primaryText"
                android:textSize="14sp" />
            <androidx.appcompat.widget.AppCompatSpinner
                android:id="@+id/sp_book_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:entries="@array/book_view"
                android:theme="@style/Spinner"
                tools:ignore="TouchTargetSizeCheck" />
        </LinearLayout>
        <!-- 鏄剧ず鏇村淇℃伅寮€鍏筹紙浠呭湪鍒楄〃瑙嗗浘鏃舵樉绀猴級 -->
        <LinearLayout
            android:id="@+id/ll_show_more_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/ll_book_view">
            <io.legado.app.lib.theme.view.ThemeSwitch
                android:id="@+id/sw_show_more_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="8dp"
                android:text="@string/show_more_info"
                android:textSize="14sp"
                tools:ignore="TouchTargetSizeCheck" />
            <!-- 瀛愯彍鍗曪細鏄剧ず鏍囩 -->
            <io.legado.app.lib.theme.view.ThemeSwitch
                android:id="@+id/sw_show_tags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="8dp"
                android:layout_marginStart="16dp"
                android:text="@string/show_tags"
                android:textSize="14sp"
                android:visibility="gone"
                tools:ignore="TouchTargetSizeCheck" />
            <!-- 瀛愯彍鍗曪細鏄剧ず绠€浠?-->
            <io.legado.app.lib.theme.view.ThemeSwitch
                android:id="@+id/sw_show_intro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="8dp"
                android:layout_marginStart="16dp"
                android:text="@string/show_intro"
                android:textSize="14sp"
                android:visibility="gone"
                tools:ignore="TouchTargetSizeCheck" />
            <!-- 绠€浠嬭鏁伴€夋嫨锛堜粎鍦ㄦ樉绀虹畝浠嬪嬀閫夋椂鏄剧ず锛岀偣鍑诲脊鍑?NumberPicker锛?-->
            <TextView
                android:id="@+id/tv_intro_lines"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="32dp"
                android:paddingVertical="8dp"
                android:text="@string/intro_lines"
                android:textColor="@color/primaryText"
                android:textSize="14sp"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackground" />
        </LinearLayout>
        <!-- 鏄剧ず鏈鏁板紑鍏?-->
        <io.legado.app.lib.theme.view.ThemeSwitch
            android:id="@+id/sw_show_unread"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:paddingVertical="8dp"
            android:text="@string/show_unread"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@+id/ll_show_more_info"
            tools:ignore="TouchTargetSizeCheck" />
        <!-- 鏄剧ず鏈€鍚庢洿鏂版椂闂村紑鍏?-->
        <io.legado.app.lib.theme.view.ThemeSwitch
            android:id="@+id/sw_show_last_update_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="8dp"
            android:text="@string/show_last_update_time"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@+id/sw_show_unread"
            tools:ignore="TouchTargetSizeCheck" />
        <!-- 鏄剧ず绛夊緟鏇存柊涔︾睄鏁板紑鍏?-->
        <io.legado.app.lib.theme.view.ThemeSwitch
            android:id="@+id/sw_show_wait_up_books"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="8dp"
            android:text="@string/show_wait_up_count"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@+id/sw_show_last_update_time"
            tools:ignore="TouchTargetSizeCheck" />
        <!-- 鏄剧ず蹇€熸粴鍔ㄦ潯寮€鍏?-->
        <io.legado.app.lib.theme.view.ThemeSwitch
            android:id="@+id/sw_show_bookshelf_fast_scroller"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="8dp"
            android:text="@string/show_bookshelf_fast_scroller"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@+id/sw_show_wait_up_books"
            tools:ignore="TouchTargetSizeCheck" />
        <!-- 鎺掑簭閫夐」 -->
        <LinearLayout
            android:id="@+id/ll_sort"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/sw_show_bookshelf_fast_scroller">
            <io.legado.app.ui.widget.text.AccentTextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingVertical="8dp"
                android:text="@string/sort"
                android:textSize="14sp" />
            <RadioGroup
                android:id="@+id/rg_sort"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <RadioButton
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="4dp"
                    android:text="@string/bookshelf_px_0"
                    android:textSize="14sp"
                    tools:ignore="TouchTargetSizeCheck" />
                <RadioButton
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="4dp"
                    android:text="@string/bookshelf_px_1"
                    android:textSize="14sp"
                    tools:ignore="TouchTargetSizeCheck" />
                <RadioButton
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="4dp"
                    android:text="@string/bookshelf_px_2"
                    android:textSize="14sp"
                    tools:ignore="TouchTargetSizeCheck" />
                <RadioButton
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="4dp"
                    android:text="@string/bookshelf_px_3"
                    android:textSize="14sp"
                    tools:ignore="TouchTargetSizeCheck" />
                <RadioButton
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="4dp"
                    android:text="@string/bookshelf_px_4"
                    android:textSize="14sp"
                    tools:ignore="TouchTargetSizeCheck" />
                <RadioButton
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="4dp"
                    android:text="@string/bookshelf_px_5"
                    android:textSize="14sp"
                    tools:ignore="TouchTargetSizeCheck" />
            </RadioGroup>
        </LinearLayout>
        <!-- 涔﹀悕鏄剧ず閫夐」 -->
        <LinearLayout
            android:id="@+id/book_name_choice"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@+id/ll_sort">
            <io.legado.app.ui.widget.text.AccentTextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingVertical="8dp"
                android:text="@string/book_name"
                android:textSize="14sp" />
            <RadioGroup
                android:id="@+id/rgb_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <RadioButton
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingVertical="4dp"
                    android:paddingHorizontal="8dp"
                    android:text="@string/show"
                    android:textSize="14sp"
                    tools:ignore="TouchTargetSizeCheck" />
                <RadioButton
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingVertical="4dp"
                    android:paddingHorizontal="8dp"
                    android:text="@string/hide"
                    android:textSize="14sp"
                    tools:ignore="TouchTargetSizeCheck" />
                <RadioButton
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingVertical="4dp"
                    android:paddingHorizontal="8dp"
                    android:text="@string/overlay"
                    android:textSize="14sp"
                    tools:ignore="TouchTargetSizeCheck" />
            </RadioGroup>
        </LinearLayout>
        <!-- 闂磋窛璁剧疆 -->
        <io.legado.app.ui.widget.DetailSeekBar
            android:id="@+id/margin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/book_name_choice"
            app:max="60"
            app:title="@string/margin" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>